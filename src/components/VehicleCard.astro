---
import Icon from './Icon.astro';
import { whatsappFor } from '../data/site';
import { priceLabel, type Vehicle } from '../data/inventory';
interface Props { vehicle: Vehicle; index?: number; }
const { vehicle: v, index = 0 } = Astro.props;
const href = `/lhd-cars-for-sale/${v.brandSlug}/${v.slug}`;
const wa = whatsappFor(`Hi, I'd like to enquire about the ${v.title}${v.year ? ` (${v.year})` : ''} please`);
const eager = index < 4;
const specs = [
  v.year ? String(v.year) : null,
  v.fuel,
  v.transmission ? (v.transmission.startsWith('Auto') ? 'Automatic' : 'Manual') : null,
].filter(Boolean);
const modelName = v.title.replace(new RegExp(`^${v.brand}\\s+`, 'i'), '');
---
<article
  class={`ed-vehicle group fade-in stagger-${(index % 4) + 1} ${v.tier === 'ultra' ? 'tier-ultra' : ''}`}
  data-brand={v.brand}
  data-status={v.status}
  data-body={v.body || ''}
  data-fuel={v.fuel || ''}
  data-trans={v.transmission ? (v.transmission.startsWith('Auto') ? 'Automatic' : 'Manual') : ''}
  data-price={v.price ?? ''}
  data-year={v.year ?? ''}
  data-title={v.title}
>
  <a href={href} class="block" aria-label={`View ${v.title}`}>
    <div class="ed-vehicle-media">
      <img src={v.image} alt={`Left-hand drive ${v.title}`} width="700" height="525" loading={eager ? 'eager' : 'lazy'} />
      <span class={`badge absolute top-3 left-3 ${v.status === 'sold' ? 'badge-sold' : v.status === 'call' ? 'badge-call' : 'badge-available'}`}>
        {v.status === 'sold' ? 'Sold' : v.status === 'call' ? 'Call us' : 'Available'}
      </span>
      {v.tier === 'ultra' && <span class="badge badge-tier absolute top-3 right-3">Ultra</span>}
    </div>
  </a>
  <div class="ed-vehicle-meta mt-1">
    <div>
      <p class="text-[0.62rem] font-mono uppercase tracking-[0.22em] text-muted mb-1">{v.brand}{v.year ? ` · ${v.year}` : ''} · {v.location}</p>
      <a href={href}><p class="font-display text-ink text-[1.05rem] leading-snug font-semibold group-hover:text-red-deep transition pr-2">{modelName}</p></a>
      {specs.length > 0 && <p class="text-[0.8rem] text-muted font-mono mt-1.5">{specs.join('  ·  ')}</p>}
    </div>
    <p class={`price text-lg whitespace-nowrap ${v.status === 'sold' ? 'price-sold' : v.status === 'call' ? 'price-call' : ''}`}>{priceLabel(v)}</p>
  </div>
  <div class="flex items-center gap-3 mt-4">
    <a href={href} class="ed-cta" style="padding: 0.55rem 0; font-size: 0.66rem;">
      Details<span class="ed-cta-arrow" style="width:30px;height:30px;"><Icon name="ArrowRight" size={13} strokeWidth={2.2} /></span>
    </a>
    <a href={wa} target="_blank" rel="noopener" class="ml-auto inline-flex items-center justify-center w-9 h-9 rounded-full border border-line text-muted hover:text-red-deep hover:border-red/40 transition" aria-label={`Enquire about ${v.title} on WhatsApp`}>
      <Icon name="MessageCircle" size={14} strokeWidth={2.2} />
    </a>
  </div>
</article>
