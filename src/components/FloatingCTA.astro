---
import { telLandline, telMobile, whatsappLink, site } from '../data/site';
import Icon from './Icon.astro';
---
<div class="floating-mobile fixed bottom-2 left-0 right-0 z-40 px-2 gap-1.5 pointer-events-none">
  <a href={telLandline} class="btn btn-navy pointer-events-auto flex-1 !py-1.5 !px-2 !gap-1.5 !text-[0.72rem] !font-mono !font-semibold whitespace-nowrap" aria-label={`Call our landline ${site.phoneLandline}`}>
    <Icon name="Phone" size={12} strokeWidth={2.4} />
    {site.phoneLandline}
  </a>
  <a href={telMobile} class="btn btn-primary pointer-events-auto flex-1 !py-1.5 !px-2 !gap-1.5 !text-[0.72rem] !font-mono !font-semibold whitespace-nowrap" aria-label={`Call our mobile ${site.phoneMobile}`}>
    <Icon name="Phone" size={12} strokeWidth={2.4} />
    {site.phoneMobile}
  </a>
  <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp pointer-events-auto !py-1.5 !px-3" aria-label="Enquire about an LHD car on WhatsApp">
    <Icon name="MessageCircle" size={16} strokeWidth={2.2} />
  </a>
</div>
