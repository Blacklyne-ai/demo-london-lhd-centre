---
import Icon from './Icon.astro';
import { site } from '../data/site';
interface Props { heading?: string; intro?: string; showHeading?: boolean; locations?: typeof site.locations; }
const {
  heading = 'Two London locations',
  intro = 'Visit us in Barnes or Chelsea Harbour. Our Barnes site is the main showroom and inventory base; Chelsea Harbour serves our premium clientele by appointment.',
  showHeading = true,
  locations = site.locations,
} = Astro.props;

const addressLines = (loc: typeof site.locations[number]) => {
  const l1 = loc.street;
  const areaPart = loc.area && loc.area !== loc.street ? `${loc.area}, ` : '';
  const l2 = `${areaPart}${loc.city} ${loc.postcode}`;
  return [l1, l2];
};
---
<div>
  {showHeading && (
    <div class="max-w-2xl mb-10 fade-in">
      <span class="eyebrow mb-5">Where to find us</span>
      <h2 class="heading-lg text-ink text-balance mt-1 mb-4">{heading}</h2>
      <p class="text-muted leading-relaxed text-pretty">{intro}</p>
    </div>
  )}
  <div class="grid lg:grid-cols-2 gap-6">
    {locations.map((loc, i) => (
      <div class={`card !p-0 overflow-hidden flex flex-col fade-in stagger-${i + 1}`}>
        <div class="relative overflow-hidden" style="min-height:260px;">
          <iframe
            src={loc.mapsEmbed}
            title={`Map showing ${site.shortName}, ${loc.area}, ${loc.postcode}`}
            width="100%" height="100%"
            style="border:0; min-height:260px; display:block;"
            loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen
          ></iframe>
        </div>
        <div class="p-6 md:p-7 flex flex-col flex-1 border-t border-line">
          <span class={`badge ${loc.primary ? 'badge-available' : 'badge-call'} self-start mb-3`}>{loc.primary ? 'Main showroom' : 'By appointment'}</span>
          <h3 class="heading-md text-ink mb-1">{site.shortName} — {loc.name}</h3>
          <p class="text-[0.78rem] uppercase tracking-[0.14em] font-mono text-muted mb-5">{loc.role}</p>
          <address class="not-italic text-ink leading-relaxed mb-6 flex items-start gap-3">
            <span class="tile-icon tile-icon-red flex-shrink-0" style="width:42px;height:42px;"><Icon name="MapPin" size={18} strokeWidth={2} /></span>
            <span>
              {addressLines(loc).map((line, idx) => (idx === 0 ? <span class="font-semibold">{line}</span> : <><br />{line}</>))}
            </span>
          </address>
          <div class="flex flex-col sm:flex-row gap-3 mt-auto">
            <a href={loc.directionsUrl} target="_blank" rel="noopener" class="btn btn-navy btn-sm flex-1">
              <Icon name="Navigation" size={15} strokeWidth={2.2} /> Directions
            </a>
            <a href={loc.mapsUrl} target="_blank" rel="noopener" class="btn btn-outline btn-sm flex-1">
              <Icon name="MapPinned" size={15} strokeWidth={2.2} /> Open in Maps
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
