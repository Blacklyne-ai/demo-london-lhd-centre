---
import { site, telLandline, telMobile, mailLink, whatsappLink, legalNav, footerNav } from '../data/site';
import { brandSegments } from '../data/brands';
import Icon from './Icon.astro';
const year = new Date().getFullYear();

const midRange = [
  { label: 'Ford', href: '/lhd-cars-for-sale/ford' },
  { label: 'Nissan', href: '/lhd-cars-for-sale/nissan' },
  { label: 'Mazda', href: '/lhd-cars-for-sale' },
  { label: 'Toyota', href: '/lhd-cars-for-sale' },
  { label: 'VW', href: '/lhd-cars-for-sale' },
];
const highEnd = [
  { label: 'Audi', href: '/lhd-cars-for-sale/audi' },
  { label: 'BMW', href: '/lhd-cars-for-sale' },
  { label: 'Ferrari', href: '/lhd-cars-for-sale/ferrari' },
  { label: 'Mercedes', href: '/lhd-cars-for-sale/mercedes-benz' },
  { label: 'Porsche', href: '/lhd-cars-for-sale/porsche' },
];
---

<footer class="bg-navy-ink text-white/70 pt-20 pb-8 relative overflow-hidden">
  <div class="absolute inset-0 opacity-70 pointer-events-none" style="background: radial-gradient(circle at 88% 8%, rgba(200,16,46,0.10) 0%, transparent 45%), radial-gradient(circle at 5% 95%, rgba(79,137,194,0.16) 0%, transparent 45%);"></div>

  <div class="container-mcp relative">
    <div class="grid md:grid-cols-12 gap-10 pb-12 border-b border-white/10">
      <!-- Brand -->
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-2.5 mb-5" aria-label={site.name}>
          <img src="/logo.png" alt="London LHD Centre" width="150" height="58" class="h-8 w-auto" />
          <span class="flex flex-col leading-none border-l border-white/20 pl-2.5">
            <span class="font-display font-extrabold text-white text-[0.95rem] tracking-[-0.02em]">LHD CENTRE</span>
            <span class="text-[0.55rem] uppercase tracking-[0.22em] text-white/45 font-mono mt-0.5">Since 1995</span>
          </span>
        </a>
        <p class="text-sm text-white/55 leading-relaxed max-w-xs mb-5">
          The UK’s leading left-hand drive car dealer, with over 30 years of experience. Buying and selling LHD cars from Skoda to Ferrari across two London showrooms, with delivery worldwide.
        </p>
        <div class="flex items-center gap-2.5">
          <a href={site.facebookUrl} target="_blank" rel="noopener" aria-label="London LHD Centre on Facebook" class="inline-flex items-center gap-2 px-3.5 h-10 rounded-full border border-white/12 text-white/75 hover:text-white hover:border-red transition text-xs font-semibold" style="background: rgba(255,255,255,0.04);">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-7h2.3l.4-2.7h-2.7V9.5c0-.8.2-1.3 1.3-1.3h1.5V5.8c-.7-.1-1.5-.1-2.2-.1-2.1 0-3.5 1.3-3.5 3.6v2H8.2v2.7h2.4V21h2.9z"/></svg> Facebook
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener" aria-label="WhatsApp us" class="w-10 h-10 rounded-full inline-flex items-center justify-center border border-white/12 text-white/75 hover:text-white hover:border-red transition" style="background: rgba(255,255,255,0.04);">
            <Icon name="MessageCircle" size={17} />
          </a>
        </div>
      </div>

      <!-- Explore -->
      <div class="md:col-span-3">
        <h3 class="text-white font-semibold mb-4 text-[0.7rem] tracking-[0.18em] uppercase font-mono">Explore</h3>
        <ul class="space-y-2.5 text-sm">
          {footerNav.map((i) => (<li><a href={i.href} class="text-white/55 hover:text-red-bright transition">{i.label}</a></li>))}
        </ul>
      </div>

      <!-- Brands -->
      <div class="md:col-span-2">
        <h3 class="text-white font-semibold mb-3 text-[0.7rem] tracking-[0.18em] uppercase font-mono">Mid Range</h3>
        <ul class="space-y-2 text-sm mb-5">
          {midRange.map((i) => (<li><a href={i.href} class="text-white/55 hover:text-red-bright transition">{i.label}</a></li>))}
        </ul>
        <h3 class="text-white font-semibold mb-3 text-[0.7rem] tracking-[0.18em] uppercase font-mono">High End</h3>
        <ul class="space-y-2 text-sm">
          {highEnd.map((i) => (<li><a href={i.href} class="text-white/55 hover:text-red-bright transition">{i.label}</a></li>))}
        </ul>
      </div>

      <!-- Contact & visit -->
      <div class="md:col-span-3">
        <h3 class="text-white font-semibold mb-4 text-[0.7rem] tracking-[0.18em] uppercase font-mono">Contact &amp; Visit</h3>
        <ul class="space-y-2 text-sm mb-4">
          <li class="flex items-center gap-2"><span class="text-white/40 text-xs w-16">Landline</span> <a href={telLandline} class="text-white hover:text-red-bright transition font-medium font-mono">{site.phoneLandline}</a></li>
          <li class="flex items-center gap-2"><span class="text-white/40 text-xs w-16">Mobile</span> <a href={telMobile} class="text-white hover:text-red-bright transition font-medium font-mono">{site.phoneMobile}</a></li>
          <li class="flex items-center gap-2"><span class="text-white/40 text-xs w-16">Email</span> <a href={mailLink} class="text-white/55 hover:text-red-bright transition break-all">{site.email}</a></li>
          <li class="flex items-start gap-2"><span class="text-white/40 text-xs w-16 flex-shrink-0">Intl</span> <span class="text-white/55 font-mono">{site.phoneLandlineDial}</span></li>
        </ul>
        <div class="space-y-3 text-sm text-white/55 leading-relaxed">
          {site.locations.map((loc) => (
            <address class="not-italic">
              <span class="text-white/80 font-medium">{loc.name}</span><br />
              {loc.street !== loc.area ? <>{loc.street}, </> : ''}{loc.city} {loc.postcode}
            </address>
          ))}
        </div>
      </div>
    </div>

    <div class="py-6 border-b border-white/10 grid sm:grid-cols-2 gap-3 text-sm text-white/55">
      <p class="flex items-center gap-2"><Icon name="Phone" size={14} strokeWidth={2} class="text-red-bright" /> Telephone enquiries · {site.phoneHours.days} · {site.phoneHours.value}</p>
      <p class="flex items-center gap-2 sm:justify-end"><Icon name="Store" size={14} strokeWidth={2} class="text-red-bright" /> Barnes showroom · {site.showroomHours.days} · {site.showroomHours.value}</p>
    </div>

    <div class="pt-6 flex flex-col md:flex-row md:justify-between gap-3 text-xs text-white/45">
      <p>© {year} {site.name}. All rights reserved.</p>
      <div class="flex flex-wrap gap-5">
        {legalNav.map((i) => (<a href={i.href} class="hover:text-red-bright transition">{i.label}</a>))}
        <a href="/sitemap" class="hover:text-red-bright transition">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
