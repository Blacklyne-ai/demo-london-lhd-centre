---
// Typographic brand monogram badge. We deliberately do NOT reproduce
// trademarked car-brand logos — a clean, consistent wordmark monogram
// avoids any trademark issue while reading as a premium brand mark.
interface Props { mark: string; tier?: string; size?: number; class?: string; }
const { mark, tier = 'standard', size = 56, class: cls = '' } = Astro.props;
const style = `width:${size}px;height:${size}px;font-size:${Math.round(size * 0.34)}px;` +
  (tier === 'ultra' ? 'color:var(--c-gold);border-color:rgba(212,175,55,0.5);' : '');
---
<span class={`brand-badge ${cls}`} style={style} aria-hidden="true">{mark}</span>
