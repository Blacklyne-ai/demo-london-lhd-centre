---
import Icon from './Icon.astro';
import { site } from '../data/site';
import { reviewsMeta } from '../data/reviews';
interface Props { dark?: boolean; }
const { dark = true } = Astro.props;

const stats = [
  { value: site.stats.yearsExperience, suffix: '+', label: 'Years of experience' },
  { value: site.stats.brandsCovered, suffix: '+', label: 'Brands covered' },
  { value: site.stats.locations, suffix: '', label: 'London locations' },
];
const fmt = (n: number) => n.toLocaleString('en-GB');
const googleSearch = 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent('London LHD Centre');
---
<section class={dark ? 'section-navy py-24 md:py-32 relative overflow-hidden' : 'section-snow py-24 md:py-32'}>
  {dark && <div class="glow-orb" style="width: 460px; height: 460px; top: 10%; left: -140px; background: #C8102E; opacity: 0.12;"></div>}
  <div class="container-mcp relative">
    <div class="text-center max-w-2xl mx-auto mb-14 fade-in">
      <span class={`eyebrow eyebrow-center ${dark ? 'eyebrow-light' : ''} mb-5`}>Trusted since 1995</span>
      <h2 class={`heading-lg text-balance mt-1 ${dark ? 'text-white' : ''}`}>What our customers say</h2>
    </div>

    {reviewsMeta.googleAvailable && reviewsMeta.reviews.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reviewsMeta.reviews.map((r) => (
          <div class={`rounded-2xl p-7 ${dark ? 'glass' : 'card'}`}>
            <span class="stars mb-3">{Array.from({ length: r.rating }).map(() => (
              <svg width="18" height="18" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            ))}</span>
            <p class={`leading-relaxed mb-4 ${dark ? 'text-white/80' : 'text-muted'}`}>“{r.text}”</p>
            <p class={`text-sm font-semibold ${dark ? 'text-white' : 'text-ink'}`}>{r.author}{r.location ? ` · ${r.location}` : ''}</p>
          </div>
        ))}
      </div>
    ) : (
      <div class="grid lg:grid-cols-2 gap-6 items-stretch">
        <!-- Trust anchor: real, verifiable facts (not invented reviews) -->
        <div class={`fade-in rounded-[1.75rem] p-8 md:p-10 flex flex-col justify-center ${dark ? 'glass' : 'card'}`}>
          <span class="stars mb-4">{Array.from({ length: 5 }).map(() => (
            <svg width="22" height="22" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}</span>
          <p class={`text-lg leading-relaxed mb-6 ${dark ? 'text-white/75' : 'text-muted'}`}>
            <strong class={dark ? 'text-white' : 'text-ink'}>Over 30 years, thousands of customers</strong> have bought and sold left-hand drive cars with us, across the UK, Europe and beyond.
          </p>
          <a href={googleSearch} target="_blank" rel="noopener" class="btn btn-primary self-start">
            <Icon name="Star" size={16} strokeWidth={2.2} />
            Review us on Google
            <Icon name="ExternalLink" size={15} strokeWidth={2.2} />
          </a>
        </div>

        <!-- Stats + Google review invite -->
        <div class="flex flex-col gap-6">
          <div class="grid grid-cols-3 gap-3 fade-in stagger-1">
            {stats.map((s) => (
              <div class={`rounded-2xl p-5 text-center ${dark ? 'glass' : 'card'}`}>
                <p class={`big-number ${dark ? 'text-white' : 'text-ink'}`} style="font-size: clamp(1.8rem,4vw,2.6rem);"><span data-count={s.value} data-suffix={s.suffix}>{fmt(s.value)}{s.suffix}</span></p>
                <p class={`text-[0.62rem] md:text-[0.68rem] uppercase tracking-widest mt-2 font-mono ${dark ? 'text-white/55' : 'text-muted'}`}>{s.label}</p>
              </div>
            ))}
          </div>
          <div class={`rounded-2xl p-6 fade-in stagger-2 flex items-start gap-4 ${dark ? 'glass' : 'card'}`}>
            <span class="tile-icon tile-icon-red flex-shrink-0"><Icon name="Star" size={22} strokeWidth={2} /></span>
            <div>
              <p class={`font-semibold mb-1 ${dark ? 'text-white' : 'text-ink'}`}>Bought or sold a car with us?</p>
              <p class={`text-[0.9rem] leading-relaxed ${dark ? 'text-white/60' : 'text-muted'}`}>{reviewsMeta.googleNote}</p>
            </div>
          </div>
        </div>
      </div>
    )}
  </div>
</section>
