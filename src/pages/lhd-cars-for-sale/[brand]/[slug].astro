---
import Layout from '../../../layouts/Layout.astro';
import Icon from '../../../components/Icon.astro';
import VehicleCard from '../../../components/VehicleCard.astro';
import QuoteForm from '../../../components/QuoteForm.astro';
import CtaBand from '../../../components/CtaBand.astro';
import { vehicles, priceLabel, relatedVehicles } from '../../../data/inventory';
import { brandBySlug } from '../../../data/brands';
import { site, telLandline, telMobile, whatsappFor, mailFor } from '../../../data/site';

export function getStaticPaths() {
  return vehicles.map((v) => ({ params: { brand: v.brandSlug, slug: v.slug }, props: { vehicle: v } }));
}
const { vehicle: v } = Astro.props;
const ref = `${v.title}${v.year ? ` (${v.year})` : ''}`;
const wa = whatsappFor(`Hi, I'd like to enquire about the ${ref} please`);
const mail = mailFor(`Enquiry: ${ref}`);
const brandPage = brandBySlug(v.brandSlug);
const related = relatedVehicles(v, 3);
const pageUrl = new URL(Astro.url.pathname, site.url).href;
const shareMail = `mailto:?subject=${encodeURIComponent(`Check out this LHD car: ${ref}`)}&body=${encodeURIComponent(`I found this left-hand drive ${v.brand} at the London LHD Centre:\n\n${ref}\n${pageUrl}`)}`;

const fmtVal = (val: string | number | null, label: string) => {
  if (val === null || val === undefined || val === '') return 'On request';
  if (label === 'Mileage' && typeof val === 'number') return `${val.toLocaleString('en-GB')} miles`;
  return String(val);
};
const specs = [
  { label: 'Year', value: v.year, icon: 'Calendar' },
  { label: 'Engine', value: v.engine, icon: 'Settings' },
  { label: 'Fuel', value: v.fuel, icon: 'Fuel' },
  { label: 'Transmission', value: v.transmission, icon: 'Cog' },
  { label: 'Body', value: v.body, icon: 'CarFront' },
  { label: 'Drive', value: v.drive, icon: 'Compass' },
  { label: 'Power', value: v.power, icon: 'Gauge' },
  { label: 'Seats', value: v.seats, icon: 'Users' },
  { label: 'Mileage', value: v.mileage, icon: 'Navigation' },
  { label: 'Colour', value: v.colour, icon: 'Sparkles' },
  { label: 'Sourced from', value: v.origin, icon: 'Globe' },
  { label: 'VAT status', value: v.vat, icon: 'Receipt' },
  { label: 'Emissions', value: v.euro, icon: 'ShieldCheck' },
  { label: 'Available at', value: `${v.location} showroom`, icon: 'MapPin' },
];
const quickSpecs = specs.filter((s) => ['Year', 'Fuel', 'Transmission', 'Body'].includes(s.label) && s.value);

const carSchema = {
  '@context': 'https://schema.org', '@type': 'Car', name: v.title,
  brand: { '@type': 'Brand', name: v.brand },
  vehicleConfiguration: v.body || undefined,
  ...(v.year ? { productionDate: String(v.year) } : {}),
  ...(v.fuel ? { fuelType: v.fuel } : {}),
  ...(v.colour ? { color: v.colour } : {}),
  steeringPosition: 'https://schema.org/LeftHandDriving',
  image: site.url + v.image,
  offers: {
    '@type': 'Offer', priceCurrency: 'GBP',
    ...(v.price ? { price: v.price } : {}),
    availability: v.status === 'sold' ? 'https://schema.org/SoldOut' : 'https://schema.org/InStock',
    seller: { '@type': 'AutoDealer', name: site.name },
  },
};
---
<Layout
  current="/lhd-cars-for-sale"
  title={`${v.title}${v.year ? ` ${v.year}` : ''} — LHD ${v.brand} | London LHD Centre`}
  description={`Left-hand drive ${v.title} for sale at the London LHD Centre. ${[v.engine, v.fuel, v.transmission].filter(Boolean).join(', ')}. ${priceLabel(v)}.`}
  ogImage={v.image}
  schema={carSchema}
>
  <!-- Detail hero -->
  <section class="pt-28 md:pt-36 pb-16 md:pb-20 bg-white">
    <div class="container-mcp">
      <nav class="flex items-center flex-wrap gap-2 text-[0.78rem] text-muted mb-8 fade-in" aria-label="Breadcrumb">
        <a href="/" class="hover:text-red-deep transition">Home</a>
        <Icon name="ChevronRight" size={13} strokeWidth={2.4} />
        <a href="/lhd-cars-for-sale" class="hover:text-red-deep transition">Cars For Sale</a>
        <Icon name="ChevronRight" size={13} strokeWidth={2.4} />
        {brandPage
          ? <a href={`/lhd-cars-for-sale/${v.brandSlug}`} class="hover:text-red-deep transition">{v.brand}</a>
          : <a href="/lhd-cars-for-sale" class="hover:text-red-deep transition">{v.brand}</a>}
        <Icon name="ChevronRight" size={13} strokeWidth={2.4} />
        <span class="text-ink font-medium">{v.title}</span>
      </nav>

      <div class="grid lg:grid-cols-12 gap-8 lg:gap-10 items-start">
        <!-- Gallery -->
        <div class="lg:col-span-7 fade-in">
          <div class="relative rounded-[1.75rem] overflow-hidden border border-line" style="box-shadow: var(--shadow-lift);">
            <img src={v.image} alt={`Left-hand drive ${v.title}`} width="1000" height="750" class="w-full aspect-[4/3] object-cover" loading="eager" fetchpriority="high" />
            <div class="absolute top-4 left-4 flex gap-2">
              {v.tier === 'ultra' && <span class="badge badge-tier">Ultra-premium</span>}
            </div>
            <span class={`badge absolute top-4 right-4 ${v.status === 'sold' ? 'badge-sold' : v.status === 'call' ? 'badge-call' : 'badge-available'}`}>
              {v.status === 'sold' ? 'Sold' : v.status === 'call' ? 'Call us' : 'Available'}
            </span>
          </div>
          <p class="text-[0.82rem] text-muted-light mt-3 flex items-center gap-1.5"><Icon name="Info" size={13} strokeWidth={2.2} /> Further photos available on request — WhatsApp us for the full set.</p>
        </div>

        <!-- Summary panel -->
        <div class="lg:col-span-5 fade-in stagger-1">
          <p class="eyebrow mb-3">{v.brand}{v.location ? ` · ${v.location}` : ''}</p>
          <h1 class="heading-md text-ink mb-4" style="font-size:clamp(1.6rem,3.2vw,2.2rem);">{v.title}</h1>
          <div class="flex items-center gap-3 mb-6">
            <span class={`price text-3xl ${v.status === 'sold' ? 'price-sold' : v.status === 'call' ? 'price-call' : ''}`}>{priceLabel(v)}</span>
            {v.vat && <span class="badge badge-tier">{v.vat}</span>}
          </div>

          {quickSpecs.length > 0 && (
            <div class="grid grid-cols-2 gap-2.5 mb-6">
              {quickSpecs.map((s) => (
                <div class="rounded-xl border border-line bg-snow px-3.5 py-3">
                  <p class="text-[0.62rem] uppercase tracking-[0.14em] text-muted font-mono mb-0.5">{s.label}</p>
                  <p class="font-mono font-semibold text-ink text-[0.92rem]">{s.value}</p>
                </div>
              ))}
            </div>
          )}

          <div class="flex flex-col gap-2.5">
            <a href={wa} target="_blank" rel="noopener" class="btn btn-whatsapp btn-block"><Icon name="MessageCircle" size={17} strokeWidth={2.2} /> Enquire on WhatsApp</a>
            <div class="grid grid-cols-2 gap-2.5">
              <a href={telLandline} class="btn btn-navy"><Icon name="Phone" size={15} strokeWidth={2.2} /> Call</a>
              <a href={mail} class="btn btn-outline"><Icon name="Mail" size={15} strokeWidth={2.2} /> Email</a>
            </div>
            <a href={shareMail} class="text-[0.85rem] font-semibold text-muted hover:text-red-deep transition inline-flex items-center gap-1.5 mt-1 self-start"><Icon name="Share2" size={14} strokeWidth={2.2} /> Send to a friend</a>
          </div>

          <div class="mt-6 pt-6 border-t border-line flex items-start gap-3 text-[0.88rem] text-muted">
            <Icon name="FileCheck" size={18} strokeWidth={2} class="text-red-deep flex-shrink-0 mt-0.5" />
            <p>UK registration service available — we can put this car onto UK plates and provide COC papers for EU supplied cars.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Full specification -->
  <section class="py-16 md:py-20 section-snow">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-12">
        <div class="lg:col-span-7">
          <h2 class="heading-md text-ink mb-6">Full specification</h2>
          <div class="card !p-6 md:!p-8">
            {specs.map((s) => (
              <div class="spec-row">
                <span class="spec-label"><Icon name={s.icon} size={16} strokeWidth={2} class="text-muted-light" />{s.label}</span>
                <span class="spec-value">{fmtVal(s.value as any, s.label)}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="lg:col-span-5">
          <h2 class="heading-md text-ink mb-6">About this car</h2>
          <div class="card-navy">
            <p class="text-white/85 leading-relaxed mb-4">
              A genuine left-hand drive {v.brand}{v.year ? `, registered ${v.year}` : ''}.
              {[v.engine, v.fuel, v.transmission].filter(Boolean).length ? ` ${[v.engine, v.fuel, v.transmission].filter(Boolean).join(', ')}.` : ''}
              {v.colour ? ` Finished in ${v.colour}${v.origin ? `, sourced from ${v.origin}` : ''}.` : (v.origin ? ` Sourced from ${v.origin}.` : '')}
            </p>
            <p class="text-white/65 text-[0.92rem] leading-relaxed">Available to view at our {v.location} showroom by appointment. We can arrange delivery throughout the UK, Europe, the USA and the Middle East.</p>
            <div class="flex flex-wrap gap-2 mt-5">
              <span class="pill pill-dark">Left hand drive</span>
              <span class="pill pill-dark">UK registration</span>
              <span class="pill pill-dark">Worldwide delivery</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Enquiry -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container-mcp">
      <div class="max-w-2xl mx-auto">
        <div class="text-center mb-8 fade-in">
          <span class="eyebrow eyebrow-center mb-5">Enquire</span>
          <h2 class="heading-lg text-balance mt-1">Interested in this {v.brand}?</h2>
          <p class="text-muted mt-3">Send us a message and we’ll be straight back with full details, photos and availability.</p>
        </div>
        <QuoteForm mode="enquiry" vehicleRef={ref} title={`Enquire about the ${v.brand}`} intro="Your enquiry comes straight to our team. We’ll reply with full details, more photos and next steps." />
      </div>
    </div>
  </section>

  {related.length > 0 && (
    <section class="py-16 md:py-24 section-snow">
      <div class="container-mcp">
        <div class="flex items-end justify-between gap-4 mb-10 fade-in">
          <div>
            <span class="eyebrow mb-4">You may also like</span>
            <h2 class="heading-lg text-balance mt-1">Similar LHD cars</h2>
          </div>
          <a href="/lhd-cars-for-sale" class="btn btn-navy hidden sm:inline-flex">All stock<Icon name="ArrowRight" size={14} strokeWidth={2.4} /></a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
          {related.map((rv, i) => <VehicleCard vehicle={rv} index={i} />)}
        </div>
      </div>
    </section>
  )}

  <CtaBand />
</Layout>
