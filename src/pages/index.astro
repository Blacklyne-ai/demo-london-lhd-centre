---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BrandStrip from '../components/BrandStrip.astro';
import VehicleCard from '../components/VehicleCard.astro';
import BrandMark from '../components/BrandMark.astro';
import MapBlock from '../components/MapBlock.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import CtaBand from '../components/CtaBand.astro';
import { site, telLandline, whatsappLink, trustSignals } from '../data/site';
import { featuredBrands, activeBrands } from '../data/brands';
import { vehicles } from '../data/inventory';
import { sellingPromises, latestNews, aboutStory } from '../data/content';

const featuredSlugs = [
  '12c-spider-3-8-2013', 's2000', 'q5-2-0-diesel-2020', 'sl-560-v8-auto-1989',
  'macan-s-3-0-v6-pdk', 'sorento-1-6-hybrid-2022', 'discovery-sport-p300e-2023', 'ghost-6-6-v12-auto',
];
const featured = featuredSlugs
  .map((s) => vehicles.find((v) => v.slug === s))
  .filter((v): v is NonNullable<typeof v> => Boolean(v));

const heroStats = [
  { value: site.stats.yearsExperience, suffix: '+', label: 'Years of experience' },
  { value: site.stats.brandsCovered, suffix: '+', label: 'Brands covered' },
  { value: site.stats.locations, suffix: '', label: 'London locations' },
  { display: String(site.stats.sinceYear), label: 'Established' },
];
const fmt = (n: number) => n.toLocaleString('en-GB');
---

<Layout
  current="/"
  title="Left Hand Drive Cars for Sale in London | London LHD Centre"
  description="Discover London LHD Centre, your premier destination for left hand drive car sales in the UK. Explore our showroom today! | London Left Hand Drive Centre"
>
  <!-- ════════ HERO — cinematic full-bleed editorial ════════ -->
  <section class="hero relative w-full min-h-screen overflow-hidden bg-navy-ink">
    <!-- Background image -->
    <img src="/images/home-1.jpg" alt="" aria-hidden="true" class="hero-bg absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" />
    <!-- Layered overlays for cinematic depth -->
    <div class="absolute inset-0" style="background: linear-gradient(120deg, rgb(5 11 20 / 0.85) 0%, rgb(5 11 20 / 0.55) 38%, rgb(5 11 20 / 0.35) 60%, rgb(5 11 20 / 0.75) 100%);"></div>
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgb(5 11 20 / 0.4) 0%, transparent 30%, transparent 65%, rgb(5 11 20 / 0.85) 100%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(60% 80% at 18% 50%, rgb(200 16 46 / 0.1) 0%, transparent 60%);"></div>

    <!-- Editorial content -->
    <div class="relative z-10 min-h-screen flex flex-col">
      <div class="flex-1 flex items-center pt-28 lg:pt-40 pb-32">
        <div class="container-mcp w-full">
          <div class="max-w-5xl">
            <!-- Eyebrow -->
            <div class="flex items-center gap-4 mb-10 lg:mb-14 fade-in">
              <span class="block h-px w-10 bg-red"></span>
              <span class="text-white/80 text-[0.72rem] font-mono uppercase tracking-[0.32em]">Since 1995 — The UK's leading LHD specialist</span>
            </div>

            <!-- Editorial headline with serif italic accent — the WOW move -->
            <h1 class="text-white text-balance fade-in stagger-1" style="font-family: var(--font-sans); font-size: clamp(3rem, 8vw, 8rem); font-weight: 300; line-height: 0.96; letter-spacing: -0.035em;">
              <span class="block">We buy and sell</span>
              <span class="block"><em class="hero-italic">Left&nbsp;Hand&nbsp;Drive</em></span>
              <span class="block font-semibold">cars in London.</span>
            </h1>

            <!-- Sub + CTA -->
            <div class="mt-10 lg:mt-14 grid lg:grid-cols-12 gap-8 items-end">
              <div class="lg:col-span-6 fade-in stagger-2">
                <p class="text-white/75 text-lg leading-relaxed max-w-md text-pretty">
                  The UK's leading LHD dealer for over 30 years — from everyday Skodas to ultra-premium Ferraris, McLarens and Rolls-Royces. Two London showrooms. Worldwide delivery.
                </p>
              </div>
              <div class="lg:col-span-6 flex items-center justify-start lg:justify-end gap-4 fade-in stagger-3">
                <a href="/lhd-cars-for-sale" class="hero-cta group">
                  <span>View Latest Stock</span>
                  <span class="hero-cta-arrow"><Icon name="ArrowRight" size={18} strokeWidth={2.2} /></span>
                </a>
                <a href={whatsappLink} target="_blank" rel="noopener" class="hidden sm:inline-flex items-center gap-2 text-white/85 hover:text-white text-sm font-medium border-b border-white/30 hover:border-white pb-1 transition-all">
                  <Icon name="MessageCircle" size={16} strokeWidth={2.2} /> WhatsApp
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom metadata rail -->
      <div class="relative border-t border-white/10 backdrop-blur-sm" style="background: rgb(5 11 20 / 0.3);">
        <div class="container-mcp grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/10">
          <div class="px-5 py-5 lg:px-8 lg:py-7">
            <p class="text-[0.6rem] font-mono uppercase tracking-[0.22em] text-white/45 mb-2">Experience</p>
            <p class="text-white text-2xl lg:text-3xl font-light"><span class="font-serif italic">30+</span> <span class="text-white/60 text-lg font-sans">years</span></p>
          </div>
          <div class="px-5 py-5 lg:px-8 lg:py-7">
            <p class="text-[0.6rem] font-mono uppercase tracking-[0.22em] text-white/45 mb-2">Brands</p>
            <p class="text-white text-2xl lg:text-3xl font-light"><span class="font-serif italic">50+</span> <span class="text-white/60 text-lg font-sans">covered</span></p>
          </div>
          <div class="px-5 py-5 lg:px-8 lg:py-7">
            <p class="text-[0.6rem] font-mono uppercase tracking-[0.22em] text-white/45 mb-2">London</p>
            <p class="text-white text-2xl lg:text-3xl font-light"><span class="font-serif italic">2</span> <span class="text-white/60 text-lg font-sans">showrooms</span></p>
          </div>
          <div class="px-5 py-5 lg:px-8 lg:py-7">
            <p class="text-[0.6rem] font-mono uppercase tracking-[0.22em] text-white/45 mb-2">Delivery</p>
            <p class="text-white text-base lg:text-lg font-sans">UK · Europe · USA · Middle East</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll cue -->
    <span class="hidden lg:flex absolute bottom-32 right-8 flex-col items-center gap-3 text-white/45 text-[0.6rem] font-mono uppercase tracking-[0.3em]" style="writing-mode: vertical-rl; transform: rotate(180deg);">
      Scroll
      <span class="block w-px h-12 bg-gradient-to-t from-white/50 to-transparent"></span>
    </span>
  </section>

  <style is:global>
    .hero-italic {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 500;
      letter-spacing: -0.02em;
      color: #fff;
      background: linear-gradient(120deg, #fff 30%, #E11D3A 50%, #fff 75%);
      background-size: 200% 100%;
      background-position: 100% 0;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: hero-shine 6s ease-in-out infinite;
    }
    @keyframes hero-shine {
      0%, 100% { background-position: 100% 0; }
      50% { background-position: 0% 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-italic { animation: none; color: #fff; -webkit-text-fill-color: #fff; background: none; }
    }

    .hero-bg { transform: scale(1.05); animation: hero-zoom 24s ease-in-out infinite alternate; }
    @keyframes hero-zoom { from { transform: scale(1.05); } to { transform: scale(1.15) translate(-1%, -1%); } }
    @media (prefers-reduced-motion: reduce) { .hero-bg { animation: none; transform: none; } }

    .hero-cta {
      display: inline-flex; align-items: center; gap: 0.85rem;
      padding: 1.1rem 0;
      color: #fff;
      font-family: var(--font-sans);
      font-size: 0.86rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase;
      border-bottom: 1px solid rgba(255,255,255,0.5);
      transition: all 0.35s ease;
    }
    .hero-cta:hover { border-color: #E11D3A; gap: 1.2rem; }
    .hero-cta-arrow {
      display: inline-flex; align-items: center; justify-content: center;
      width: 38px; height: 38px;
      border: 1px solid rgba(255,255,255,0.5);
      border-radius: 999px;
      transition: all 0.4s ease;
    }
    .hero-cta:hover .hero-cta-arrow { background: #C8102E; border-color: #C8102E; transform: rotate(-45deg); }
  </style>

  <!-- Brand logo marquee -->
  <section class="py-7 md:py-8 bg-snow border-y border-line overflow-hidden">
    <div class="marquee">
      {Array.from({ length: 2 }).map(() => (
        <div class="marquee-track" aria-hidden="true">
          {activeBrands.map((b) => (
            <img src={`/images/brands/${b.slug}.png`} alt="" class="h-7 md:h-8 w-auto object-contain shrink-0" style="filter: grayscale(1); opacity: 0.55;" />
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ════════ LATEST STOCK ════════ -->
  <section class="py-24 md:py-32 bg-white">
    <div class="container-mcp">
      <SectionHeading
        eyebrow="Latest stock"
        title="Left-hand drive cars, ready to go."
        intro="A selection of our current inventory — from everyday LHD runabouts to ultra-premium supercars. Every car is genuine left-hand drive, sourced and prepared by specialists."
        ctaHref="/lhd-cars-for-sale"
        ctaLabel="View all stock"
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 md:gap-6 mt-12">
        {featured.map((v, i) => <VehicleCard vehicle={v} index={i} />)}
      </div>
    </div>
  </section>

  <!-- ════════ BRAND COVERAGE ════════ -->
  <section class="py-24 md:py-32 section-snow">
    <div class="container-mcp">
      <div class="text-center max-w-2xl mx-auto mb-12 fade-in">
        <span class="eyebrow eyebrow-center mb-5">All major brands</span>
        <h2 class="heading-lg text-balance mt-1">From Skoda to Ferrari — we cover every tier.</h2>
        <p class="text-lg text-muted mt-4 text-pretty">Browse our left-hand drive inventory by brand. Mid-range to ultra-premium, all genuine LHD.</p>
      </div>
      <div class="grid grid-cols-3 sm:grid-cols-3 lg:grid-cols-5 gap-3 md:gap-4">
        {activeBrands.map((b, i) => (
          <a href={`/lhd-cars-for-sale/${b.slug}`} class={`card !p-5 flex flex-col items-center justify-center text-center gap-3 group fade-in stagger-${(i % 5) + 1}`}>
            <BrandMark slug={b.slug} name={b.name} tier={b.tier} size={60} />
            <span class="font-semibold text-ink text-[0.92rem] leading-tight group-hover:text-red-deep transition">{b.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════ SELL YOUR CAR + 4 PROMISES ════════ -->
  <section class="section-navy py-24 md:py-32 relative overflow-hidden">
    <div class="glow-orb" style="width: 440px; height: 440px; top: -150px; left: -100px; background: #C8102E; opacity: 0.14;"></div>
    <div class="container-mcp relative">
      <div class="grid lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-5 fade-in">
          <span class="eyebrow eyebrow-light mb-5">Sell your LHD car</span>
          <h2 class="heading-lg text-white text-balance mb-5">Sell Your Left Hand Drive Car in the UK and Europe for an Instant Payment Today</h2>
          <p class="text-lg text-white/70 leading-relaxed mb-8 text-pretty">
            Our team of experts can help you with all aspects of the buying or selling process, from financing to insurance. We also offer a free valuation service, so you can get an idea of how much your car is worth.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/lhd-sell-your-car" class="btn btn-primary btn-lg">Get a free valuation<Icon name="ArrowRight" size={16} strokeWidth={2.5} /></a>
            <a href="/buying-lhd-cars" class="btn btn-glass btn-lg">How it works</a>
          </div>
        </div>
        <div class="lg:col-span-7 grid sm:grid-cols-2 gap-4">
          {sellingPromises.map((p, i) => (
            <div class={`card-navy fade-in stagger-${i + 1}`}>
              <span class="tile-icon tile-icon-red mb-4"><Icon name={p.icon} size={22} strokeWidth={2} /></span>
              <h3 class="font-bold text-white text-lg mb-2 leading-snug">{p.title}</h3>
              <p class="text-white/65 text-[0.93rem] leading-relaxed">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ HERITAGE ════════ -->
  <section class="py-24 md:py-32 bg-white">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="relative fade-in">
          <div class="relative rounded-[2rem] overflow-hidden border border-line" style="box-shadow: var(--shadow-lift);">
            <img src="/images/cars/mercedes-sl560.jpg" alt="A classic left-hand drive Mercedes-Benz SL from our inventory" width="1000" height="750" class="w-full aspect-[4/3] object-cover" loading="lazy" />
            <div class="absolute inset-0" style="background: linear-gradient(180deg, transparent 55%, rgba(5,11,20,0.45) 100%);"></div>
          </div>
          <div class="absolute -bottom-6 -right-2 md:right-6 glass-light rounded-2xl px-6 py-5 max-w-[15rem]" style="box-shadow: var(--shadow-lift);">
            <p class="big-number text-ink" style="font-size: clamp(2rem,5vw,2.75rem);"><span data-count={site.stats.yearsExperience} data-suffix="+">{site.stats.yearsExperience}+</span></p>
            <p class="text-[0.7rem] uppercase tracking-[0.16em] text-muted mt-1 font-mono">Years specialising in LHD cars</p>
          </div>
        </div>
        <div class="fade-in stagger-1">
          <span class="eyebrow mb-5">Over 30 years in left hand drive</span>
          <h2 class="heading-lg text-balance mt-1 mb-6">The UK’s most established LHD specialist.</h2>
          <p class="text-lg text-muted leading-relaxed mb-5 text-pretty">{aboutStory[0]}</p>
          <p class="text-muted leading-relaxed mb-8 text-pretty">{aboutStory[2]}</p>
          <a href="/lhd-about-us" class="arrow-link">More about the London LHD Centre</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ TWO LOCATIONS ════════ -->
  <section class="py-24 md:py-32 section-snow">
    <div class="container-mcp">
      <MapBlock />
    </div>
  </section>

  <!-- ════════ LATEST NEWS ════════ -->
  <section class="py-24 md:py-32 bg-white">
    <div class="container-mcp">
      <div class="text-center max-w-2xl mx-auto mb-14 fade-in">
        <span class="eyebrow eyebrow-center mb-5">Latest news</span>
        <h2 class="heading-lg text-balance mt-1">What’s happening at the LHD Centre.</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {latestNews.map((n, i) => (
          <div class={`card-feature group fade-in stagger-${i + 1}`}>
            <span class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5" style="background: linear-gradient(180deg, #14365A, #0A1929);">
              <Icon name={n.icon} size={24} strokeWidth={2} class="text-red-bright" />
            </span>
            <h3 class="font-bold text-lg text-ink mb-2 leading-snug">{n.title}</h3>
            <p class="text-muted text-[0.93rem] leading-relaxed">{n.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ReviewsSection dark={true} />

  <CtaBand />
</Layout>

<style>
  .hero-slide { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 1.4s cubic-bezier(0.4,0,0.2,1); }
  .hero-slide.is-active { opacity: 1; animation: kenburns 16s ease-in-out infinite alternate; }
  @media (prefers-reduced-motion: reduce) {
    .hero-slide.is-active { animation: none; }
  }
</style>

<script>
  const slides = Array.from(document.querySelectorAll('.hero-slide'));
  if (slides.length > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let i = 0;
    setInterval(() => {
      slides[i].classList.remove('is-active');
      i = (i + 1) % slides.length;
      slides[i].classList.add('is-active');
    }, 5500);
  }
</script>
