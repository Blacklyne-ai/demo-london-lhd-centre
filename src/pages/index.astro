---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BrandStrip from '../components/BrandStrip.astro';
import VehicleCard from '../components/VehicleCard.astro';
import BrandMark from '../components/BrandMark.astro';
import MapBlock from '../components/MapBlock.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import CtaBand from '../components/CtaBand.astro';
import { site, telLandline, whatsappLink, trustSignals } from '../data/site';
import { featuredBrands, activeBrands } from '../data/brands';
import { vehicles } from '../data/inventory';
import { sellingPromises, latestNews, aboutStory } from '../data/content';

const featuredSlugs = [
  '12c-spider-3-8-2013', 's2000', 'q5-2-0-diesel-2020', 'sl-560-v8-auto-1989',
  'macan-s-3-0-v6-pdk', 'sorento-1-6-hybrid-2022', 'discovery-sport-p300e-2023', 'ghost-6-6-v12-auto',
];
const featured = featuredSlugs
  .map((s) => vehicles.find((v) => v.slug === s))
  .filter((v): v is NonNullable<typeof v> => Boolean(v));

const heroStats = [
  { value: site.stats.yearsExperience, suffix: '+', label: 'Years of experience' },
  { value: site.stats.brandsCovered, suffix: '+', label: 'Brands covered' },
  { value: site.stats.locations, suffix: '', label: 'London locations' },
  { display: String(site.stats.sinceYear), label: 'Established' },
];
const fmt = (n: number) => n.toLocaleString('en-GB');
---

<Layout
  current="/"
  title="Left Hand Drive Cars for Sale in London | London LHD Centre"
  description="Discover London LHD Centre, your premier destination for left hand drive car sales in the UK. Explore our showroom today! | London Left Hand Drive Centre"
>
  <!-- ════════ HERO — cinematic full-bleed editorial ════════ -->
  <section class="hero relative w-full min-h-screen overflow-hidden bg-navy-ink">
    <!-- Background image -->
    <img src="/images/home-1.jpg" alt="" aria-hidden="true" class="hero-bg absolute inset-0 w-full h-full object-cover" loading="eager" fetchpriority="high" />
    <!-- Layered overlays for cinematic depth -->
    <div class="absolute inset-0" style="background: linear-gradient(120deg, rgb(5 11 20 / 0.85) 0%, rgb(5 11 20 / 0.55) 38%, rgb(5 11 20 / 0.35) 60%, rgb(5 11 20 / 0.75) 100%);"></div>
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgb(5 11 20 / 0.4) 0%, transparent 30%, transparent 65%, rgb(5 11 20 / 0.85) 100%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(60% 80% at 18% 50%, rgb(200 16 46 / 0.1) 0%, transparent 60%);"></div>

    <!-- Editorial content -->
    <div class="relative z-10 min-h-screen flex flex-col">
      <div class="flex-1 flex items-center pt-28 lg:pt-40 pb-32">
        <div class="container-mcp w-full">
          <div class="max-w-5xl">
            <!-- Eyebrow -->
            <div class="flex items-center gap-4 mb-10 lg:mb-14 fade-in">
              <span class="block h-px w-10 bg-red"></span>
              <span class="text-white/80 text-[0.72rem] font-mono uppercase tracking-[0.32em]">Since 1995 — The UK's leading LHD specialist</span>
            </div>

            <!-- Editorial headline with serif italic accent — the WOW move -->
            <h1 class="text-white text-balance fade-in stagger-1" style="font-family: var(--font-sans); font-size: clamp(3rem, 8vw, 8rem); font-weight: 300; line-height: 0.96; letter-spacing: -0.035em;">
              <span class="block">We buy and sell</span>
              <span class="block"><em class="hero-italic">Left&nbsp;Hand&nbsp;Drive</em></span>
              <span class="block font-semibold">cars in London.</span>
            </h1>

            <!-- Sub + CTA -->
            <div class="mt-10 lg:mt-14 grid lg:grid-cols-12 gap-8 items-end">
              <div class="lg:col-span-6 fade-in stagger-2">
                <p class="text-white/75 text-lg leading-relaxed max-w-md text-pretty">
                  The UK's leading LHD dealer for over 30 years — from everyday Skodas to ultra-premium Ferraris, McLarens and Rolls-Royces. Two London showrooms. Worldwide delivery.
                </p>
              </div>
              <div class="lg:col-span-6 flex items-center justify-start lg:justify-end gap-4 fade-in stagger-3">
                <a href="/lhd-cars-for-sale" class="hero-cta group">
                  <span>View Latest Stock</span>
                  <span class="hero-cta-arrow"><Icon name="ArrowRight" size={18} strokeWidth={2.2} /></span>
                </a>
                <a href={whatsappLink} target="_blank" rel="noopener" class="hidden sm:inline-flex items-center gap-2 text-white/85 hover:text-white text-sm font-medium border-b border-white/30 hover:border-white pb-1 transition-all">
                  <Icon name="MessageCircle" size={16} strokeWidth={2.2} /> WhatsApp
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom metadata rail -->
      <div class="relative border-t border-white/10 backdrop-blur-sm" style="background: rgb(5 11 20 / 0.3);">
        <div class="container-mcp grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/10">
          <div class="px-5 py-5 lg:px-8 lg:py-7">
            <p class="text-[0.6rem] font-mono uppercase tracking-[0.22em] text-white/45 mb-2">Experience</p>
            <p class="text-white text-2xl lg:text-3xl font-light"><span class="font-serif italic">30+</span> <span class="text-white/60 text-lg font-sans">years</span></p>
          </div>
          <div class="px-5 py-5 lg:px-8 lg:py-7">
            <p class="text-[0.6rem] font-mono uppercase tracking-[0.22em] text-white/45 mb-2">Brands</p>
            <p class="text-white text-2xl lg:text-3xl font-light"><span class="font-serif italic">50+</span> <span class="text-white/60 text-lg font-sans">covered</span></p>
          </div>
          <div class="px-5 py-5 lg:px-8 lg:py-7">
            <p class="text-[0.6rem] font-mono uppercase tracking-[0.22em] text-white/45 mb-2">London</p>
            <p class="text-white text-2xl lg:text-3xl font-light"><span class="font-serif italic">2</span> <span class="text-white/60 text-lg font-sans">showrooms</span></p>
          </div>
          <div class="px-5 py-5 lg:px-8 lg:py-7">
            <p class="text-[0.6rem] font-mono uppercase tracking-[0.22em] text-white/45 mb-2">Delivery</p>
            <p class="text-white text-base lg:text-lg font-sans">UK · Europe · USA · Middle East</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll cue -->
    <span class="hidden lg:flex absolute bottom-32 right-8 flex-col items-center gap-3 text-white/45 text-[0.6rem] font-mono uppercase tracking-[0.3em]" style="writing-mode: vertical-rl; transform: rotate(180deg);">
      Scroll
      <span class="block w-px h-12 bg-gradient-to-t from-white/50 to-transparent"></span>
    </span>
  </section>

  <style is:global>
    .hero-italic {
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 500;
      letter-spacing: -0.02em;
      color: #fff;
      background: linear-gradient(120deg, #fff 30%, #2F6DA8 50%, #fff 75%);
      background-size: 200% 100%;
      background-position: 100% 0;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: hero-shine 6s ease-in-out infinite;
    }
    @keyframes hero-shine {
      0%, 100% { background-position: 100% 0; }
      50% { background-position: 0% 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-italic { animation: none; color: #fff; -webkit-text-fill-color: #fff; background: none; }
    }

    .hero-bg { transform: scale(1.05); animation: hero-zoom 24s ease-in-out infinite alternate; }
    @keyframes hero-zoom { from { transform: scale(1.05); } to { transform: scale(1.15) translate(-1%, -1%); } }
    @media (prefers-reduced-motion: reduce) { .hero-bg { animation: none; transform: none; } }

    .hero-cta {
      display: inline-flex; align-items: center; gap: 0.85rem;
      padding: 1.1rem 0;
      color: #fff;
      font-family: var(--font-sans);
      font-size: 0.86rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase;
      border-bottom: 1px solid rgba(255,255,255,0.5);
      transition: all 0.35s ease;
    }
    .hero-cta:hover { border-color: #2F6DA8; gap: 1.2rem; }
    .hero-cta-arrow {
      display: inline-flex; align-items: center; justify-content: center;
      width: 38px; height: 38px;
      border: 1px solid rgba(255,255,255,0.5);
      border-radius: 999px;
      transition: all 0.4s ease;
    }
    .hero-cta:hover .hero-cta-arrow { background: #1E5A9C; border-color: #1E5A9C; transform: rotate(-45deg); }
  </style>

  <!-- Brand logo marquee -->
  <section class="py-7 md:py-9 bg-white border-y border-line overflow-hidden">
    <div class="marquee">
      {Array.from({ length: 2 }).map(() => (
        <div class="marquee-track" aria-hidden="true">
          {activeBrands.map((b) => (
            <img src={`/images/brands/${b.slug}.png`} alt="" class="h-7 md:h-8 w-auto object-contain shrink-0" style="filter: grayscale(1) opacity(0.55);" />
          ))}
        </div>
      ))}
    </div>
  </section>

  <!-- ════════ 01 INVENTORY — horizontal editorial showroom ════════ -->
  <section class="py-28 md:py-36 bg-white relative overflow-hidden">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-12 gap-8 items-end mb-14 lg:mb-20">
        <div class="lg:col-span-7 fade-in">
          <span class="ed-eyebrow mb-7"><span class="ed-eyebrow-num">01</span> Inventory</span>
          <h2 class="ed-heading text-balance mt-5">
            Cars from <em>everyday</em><br />to <em>extraordinary</em>.
          </h2>
        </div>
        <div class="lg:col-span-5 fade-in stagger-1">
          <p class="text-muted text-[1.05rem] leading-relaxed mb-8 text-pretty">A selection of our current left-hand drive inventory — sourced across Europe, prepared by specialists, UK-registered with COC papers on request.</p>
          <a href="/lhd-cars-for-sale" class="ed-cta">View all stock<span class="ed-cta-arrow"><Icon name="ArrowRight" size={16} strokeWidth={2.2} /></span></a>
        </div>
      </div>

      <div class="text-[0.66rem] font-mono uppercase tracking-[0.28em] text-muted mb-4 flex items-center gap-3">
        <span class="block w-8 h-px bg-muted opacity-40"></span>Drag to explore
      </div>
    </div>

    <div class="container-mcp">
      <div class="showroom-rail" id="stock-rail">
        {featured.map((v) => (
          <a href={`/lhd-cars-for-sale/${v.brandSlug}/${v.slug}`} class="ed-vehicle group">
            <div class="ed-vehicle-media">
              <img src={v.image} alt={`Left-hand drive ${v.title}`} loading="lazy" width="700" height="525" />
              <span class={`badge absolute top-3 left-3 ${v.status === 'sold' ? 'badge-sold' : v.status === 'call' ? 'badge-call' : 'badge-available'}`}>
                {v.status === 'sold' ? 'Sold' : v.status === 'call' ? 'Call us' : 'Available'}
              </span>
              {v.tier === 'ultra' && <span class="badge badge-tier absolute top-3 right-3">Ultra</span>}
            </div>
            <div class="ed-vehicle-meta mt-1">
              <div>
                <p class="text-[0.62rem] font-mono uppercase tracking-[0.22em] text-muted mb-1">{v.brand}{v.year ? ` · ${v.year}` : ''}</p>
                <p class="font-display text-ink text-[1.05rem] leading-snug font-semibold group-hover:text-red-deep transition pr-2">{v.title.replace(new RegExp(`^${v.brand}\\s+`, 'i'), '')}</p>
              </div>
              <p class={`price text-lg whitespace-nowrap ${v.status === 'sold' ? 'price-sold' : v.status === 'call' ? 'price-call' : ''}`}>{v.status === 'sold' ? 'SOLD' : v.status === 'call' ? 'Call us' : '£' + (v.price as number).toLocaleString('en-GB')}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="container-mcp"><div class="ed-divider"></div></div>

  <!-- ════════ 02 BRANDS — asymmetric editorial directory ════════ -->
  <section class="py-28 md:py-36 bg-white">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-12 gap-8 items-end mb-14 lg:mb-20">
        <div class="lg:col-span-7 fade-in">
          <span class="ed-eyebrow mb-7"><span class="ed-eyebrow-num">02</span> Brands</span>
          <h2 class="ed-heading text-balance mt-5">
            Every major marque,<br /><em>left hand drive</em>.
          </h2>
        </div>
        <div class="lg:col-span-5 fade-in stagger-1">
          <p class="text-muted text-[1.05rem] leading-relaxed text-pretty">From mid-range Skoda, Ford and Renault to ultra-premium Ferrari, McLaren and Rolls-Royce — we source, supply and register left-hand drive cars from every major brand.</p>
        </div>
      </div>

      <!-- Featured 5: ultra/premium tiles -->
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-px bg-line border-y border-line">
        {activeBrands.filter(b => b.tier === 'ultra' || b.tier === 'premium').slice(0, 5).map((b) => (
          <a href={`/lhd-cars-for-sale/${b.slug}`} class="group relative bg-white aspect-square flex flex-col items-center justify-center gap-4 p-6 transition hover:bg-snow">
            <img src={`/images/brands/${b.slug}.png`} alt={`${b.name} logo`} class="h-14 md:h-16 w-auto object-contain transition group-hover:scale-105" loading="lazy" />
            <span class="text-[0.7rem] font-mono uppercase tracking-[0.18em] text-muted group-hover:text-red-deep transition">{b.name}</span>
            <span class="absolute top-3 right-3 text-[0.55rem] font-serif italic text-muted opacity-50">{b.tier === 'ultra' ? 'Ultra' : 'Premium'}</span>
          </a>
        ))}
      </div>

      <!-- Index list: every brand -->
      <div class="mt-14 lg:mt-20 grid lg:grid-cols-12 gap-8">
        <p class="lg:col-span-3 text-[0.66rem] font-mono uppercase tracking-[0.28em] text-muted">Full directory</p>
        <div class="lg:col-span-9 grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-x-6 gap-y-3">
          {activeBrands.map((b) => (
            <a href={`/lhd-cars-for-sale/${b.slug}`} class="group inline-flex items-baseline gap-2 py-1 text-ink hover:text-red-deep transition border-b border-line">
              <span class="font-serif italic text-[0.7rem] text-muted opacity-60 group-hover:text-red-deep">{String(activeBrands.indexOf(b) + 1).padStart(2, '0')}</span>
              <span class="font-display font-semibold text-[0.92rem]">{b.name}</span>
              <Icon name="ArrowUpRight" size={11} strokeWidth={2.2} class="ml-auto opacity-30 group-hover:opacity-100 transition" />
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 03 SELLING — dark editorial with hairline-list promises ════════ -->
  <section class="py-28 md:py-40 bg-navy-ink relative overflow-hidden">
    <span class="ed-section-num ed-section-num-light absolute top-12 right-6 lg:right-10 hidden md:block" aria-hidden="true">03</span>
    <div class="container-mcp relative">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-32 fade-in">
          <span class="ed-eyebrow ed-eyebrow-light mb-7"><span class="ed-eyebrow-num" style="color: rgb(var(--rgb-red-bright)); opacity:0.95;">03</span> Selling to us</span>
          <h2 class="ed-heading ed-heading-light text-balance mt-5">
            Sell your LHD car for an <em>instant payment</em> today.
          </h2>
          <p class="text-white/65 text-[1.05rem] leading-relaxed mt-7 text-pretty max-w-md">
            Free, no-obligation valuation. We urgently require all LHD cars and will pay the best prices, then collect from anywhere in the UK or Europe.
          </p>
          <div class="mt-10">
            <a href="/lhd-sell-your-car" class="ed-cta ed-cta-light">Get a free valuation<span class="ed-cta-arrow"><Icon name="ArrowRight" size={16} strokeWidth={2.2} /></span></a>
          </div>
        </div>

        <div class="lg:col-span-7">
          <ol class="grid gap-px bg-white/10">
            {sellingPromises.map((p, i) => (
              <li class={`bg-navy-ink p-7 md:p-10 fade-in stagger-${i + 1}`}>
                <div class="grid grid-cols-12 gap-5 items-start">
                  <div class="col-span-2 lg:col-span-1">
                    <span class="font-serif italic text-white/40 text-2xl lg:text-3xl leading-none">{String(i + 1).padStart(2, '0')}</span>
                  </div>
                  <div class="col-span-10 lg:col-span-11">
                    <h3 class="text-white text-xl md:text-2xl font-light mb-3 leading-tight" style="letter-spacing:-0.02em;">{p.title}</h3>
                    <p class="text-white/65 text-[0.98rem] leading-relaxed max-w-xl">{p.body}</p>
                  </div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 04 HERITAGE — asymmetric editorial ════════ -->
  <section class="py-28 md:py-40 bg-white relative">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
        <!-- left: image -->
        <div class="lg:col-span-7 relative fade-in">
          <div class="relative overflow-hidden">
            <img src="/images/cars/mercedes-sl560.jpg" alt="A classic left-hand drive Mercedes-Benz SL from our inventory" width="1200" height="800" class="w-full aspect-[3/2] object-cover" loading="lazy" />
          </div>
          <p class="mt-4 text-[0.66rem] font-mono uppercase tracking-[0.22em] text-muted">From the showroom · Mercedes-Benz SL 560 V8</p>
        </div>

        <!-- right: editorial text with massive italic 30+ -->
        <div class="lg:col-span-5 fade-in stagger-1">
          <span class="ed-eyebrow mb-7"><span class="ed-eyebrow-num">04</span> Heritage</span>

          <div class="flex items-start gap-5 mt-5 mb-6">
            <span class="ed-italic text-red-deep" style="font-size: clamp(5rem, 10vw, 8rem); line-height: 0.85; letter-spacing:-0.04em;">30+</span>
            <span class="text-muted text-[0.66rem] font-mono uppercase tracking-[0.22em] pt-3 max-w-[8rem]">Years specialising in left-hand drive</span>
          </div>

          <h2 class="ed-heading text-balance mb-7" style="font-size: clamp(1.75rem, 3.2vw, 2.75rem);">
            The UK's most <em>established</em> LHD specialist.
          </h2>
          <p class="text-muted leading-relaxed mb-5 text-pretty">{aboutStory[0]}</p>
          <p class="text-muted leading-relaxed mb-9 text-pretty">{aboutStory[2]}</p>
          <a href="/lhd-about-us" class="ed-cta">Our story<span class="ed-cta-arrow"><Icon name="ArrowRight" size={16} strokeWidth={2.2} /></span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════ 05 LOCATIONS — editorial split ════════ -->
  <section class="py-28 md:py-40 bg-snow">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-12 gap-8 items-end mb-14 lg:mb-20">
        <div class="lg:col-span-7 fade-in">
          <span class="ed-eyebrow mb-7"><span class="ed-eyebrow-num">05</span> London</span>
          <h2 class="ed-heading text-balance mt-5">
            Two showrooms,<br /><em>one specialist</em>.
          </h2>
        </div>
        <div class="lg:col-span-5 fade-in stagger-1">
          <p class="text-muted text-[1.05rem] leading-relaxed text-pretty">Visit our main inventory base in Barnes or our premium showroom in Chelsea Harbour — by appointment.</p>
        </div>
      </div>
      <MapBlock showHeading={false} />
    </div>
  </section>

  <!-- ════════ 06 SERVICES — editorial 3-up ════════ -->
  <section class="py-28 md:py-36 bg-white">
    <div class="container-mcp">
      <div class="grid lg:grid-cols-12 gap-8 mb-14 lg:mb-20">
        <div class="lg:col-span-7 fade-in">
          <span class="ed-eyebrow mb-7"><span class="ed-eyebrow-num">06</span> Services</span>
          <h2 class="ed-heading text-balance mt-5">
            Beyond <em>buying & selling</em>.
          </h2>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-px bg-line border-y border-line">
        {latestNews.map((n, i) => (
          <div class={`bg-white p-8 lg:p-10 fade-in stagger-${i + 1} flex flex-col`}>
            <span class="font-serif italic text-muted text-[0.9rem] mb-6">{String(i + 1).padStart(2, '0')} / 03</span>
            <h3 class="font-display font-semibold text-ink text-xl mb-3 leading-snug">{n.title}</h3>
            <p class="text-muted text-[0.95rem] leading-relaxed flex-1">{n.body}</p>
            <div class="mt-6 text-red-deep">
              <Icon name={n.icon === 'Sparkles' ? 'MessageCircle' : n.icon} size={18} strokeWidth={1.8} />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ReviewsSection dark={true} />

  <!-- ════════ FINAL EDITORIAL CTA — full-bleed dark ════════ -->
  <section class="relative bg-navy-ink overflow-hidden">
    <img src="/images/home-2.jpg" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="lazy" />
    <div class="absolute inset-0" style="background: linear-gradient(120deg, rgb(5 11 20 / 0.92) 0%, rgb(5 11 20 / 0.7) 60%, rgb(5 11 20 / 0.9) 100%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(60% 80% at 20% 50%, rgb(200 16 46 / 0.15) 0%, transparent 60%);"></div>
    <div class="container-mcp relative py-28 md:py-40">
      <div class="max-w-4xl">
        <span class="ed-eyebrow ed-eyebrow-light mb-8">Get in touch</span>
        <h2 class="ed-heading ed-heading-light text-balance mt-5 mb-8" style="font-size: clamp(2.5rem, 7vw, 6rem);">
          Looking for an LHD car<br />or want to <em>sell yours</em>?
        </h2>
        <p class="text-white/65 text-lg leading-relaxed max-w-xl mb-12 text-pretty">
          Call, WhatsApp or email — our team is here Monday to Friday. Visit Barnes or Chelsea Harbour by appointment.
        </p>
        <div class="flex flex-wrap items-center gap-x-10 gap-y-6">
          <a href={telLandline} class="ed-cta ed-cta-light">{site.phoneLandline}<span class="ed-cta-arrow"><Icon name="Phone" size={15} strokeWidth={2.2} /></span></a>
          <a href={whatsappLink} target="_blank" rel="noopener" class="ed-cta ed-cta-light">WhatsApp<span class="ed-cta-arrow"><Icon name="MessageCircle" size={15} strokeWidth={2.2} /></span></a>
          <a href="/lhd-contact-us" class="ed-cta ed-cta-light">Visit us<span class="ed-cta-arrow"><Icon name="ArrowRight" size={15} strokeWidth={2.2} /></span></a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero-slide { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 1.4s cubic-bezier(0.4,0,0.2,1); }
  .hero-slide.is-active { opacity: 1; animation: kenburns 16s ease-in-out infinite alternate; }
  @media (prefers-reduced-motion: reduce) {
    .hero-slide.is-active { animation: none; }
  }
</style>

<script>
  const slides = Array.from(document.querySelectorAll('.hero-slide'));
  if (slides.length > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let i = 0;
    setInterval(() => {
      slides[i].classList.remove('is-active');
      i = (i + 1) % slides.length;
      slides[i].classList.add('is-active');
    }, 5500);
  }
</script>
