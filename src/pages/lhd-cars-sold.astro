---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import PageHero from '../components/PageHero.astro';
import VehicleCard from '../components/VehicleCard.astro';
import CtaBand from '../components/CtaBand.astro';
import { soldVehicles, vehicles } from '../data/inventory';
---
<Layout
  current="/lhd-cars-sold"
  title="LHD Cars Sold | The London Left Hand Drive Centre"
  description="A selection of recently sold left-hand drive cars at the London LHD Centre — evidence of the breadth of LHD vehicles we handle, from Skoda to Rolls-Royce."
>
  <PageHero
    eyebrow="Recently sold"
    title="LHD Cars Sold"
    crumb="Cars Sold"
    subtitle="A look at left-hand drive cars we have recently sold — from everyday runabouts to ultra-premium marques. It shows the breadth of LHD vehicles we handle, and how quickly the right car moves."
    primary={{ href: '/lhd-cars-for-sale', label: 'See available stock' }}
    secondary={{ href: '/lhd-sell-your-car', label: 'Sell your car' }}
  />

  <section class="py-24 md:py-28 bg-white">
    <div class="container-mcp">
      <div class="flex flex-wrap items-center gap-4 mb-10 fade-in">
        <span class="badge badge-sold">Sold</span>
        <p class="text-muted text-[0.95rem]">{soldVehicles.length} recently sold · seen something similar? We can source it.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {soldVehicles.map((v, i) => <VehicleCard vehicle={v} index={i} />)}
      </div>

      <div class="mt-16 card-feature text-center max-w-2xl mx-auto !py-10 fade-in">
        <span class="tile-icon tile-icon-red mx-auto mb-5"><Icon name="Search" size={24} strokeWidth={2} /></span>
        <h2 class="heading-md text-ink mb-3">Looking for one of these?</h2>
        <p class="text-muted leading-relaxed mb-7 max-w-md mx-auto">We sell left-hand drive cars quickly, and we source to order. Tell us what you’re after and we’ll find the right one.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/lhd-cars-for-sale" class="btn btn-primary">Browse current stock<Icon name="ArrowRight" size={15} strokeWidth={2.4} /></a>
          <a href="/lhd-contact-us" class="btn btn-navy">Tell us what you want</a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
